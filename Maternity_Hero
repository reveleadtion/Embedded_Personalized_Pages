    early:{
      lbl: 'Why Reaching Out Early Makes All the Difference',
      body: 'You\'re at week {w} — too early to book, but exactly the right time to get on our radar. The clients who end up with their ideal session date, their first-choice gowns, and zero last-minute stress are almost always the ones who connected with us early. Drop your details above and we\'ll take it from there.',
      isNB: false
    },
    inWindow:{
      lbl:  'You\'re in the Window — And It\'s Closing From Both Ends',
      body: 'Week {w} is ideal. But ideal weeks are exactly what everyone in your position is looking for — which means these are the first sessions to fill. We take 6 per month. The clients who book now are the ones who get the date they actually wanted.',
      isNB: false
    },
    pastWindow:{
      lbl:  'Still Bookable — But the Window Is Closing Fast',
      body: 'Week {w} is still within our booking range — you haven\'t missed it. But this tier fills quickly and the cutoff at week 32 is firm. Clients who make it work at this stage reach out the same day. Every day you wait is a session date that no longer exists for you.',
      isNB: false
    },
    urgent:{
      lbl:  'Week 32 — This Is the Final Call',
      body: 'These are the last weeks you\'ll be visibly, beautifully pregnant — and there may still be a session available for you. Week 34 is our hard cutoff. Same-week confirmation required. If we have a date open, we can still deliver the full experience: pro hair and makeup, designer gowns, fully guided.',
      isNB: false
    },
    late:{
      lbl:  'Maternity Is Closing — Here\'s What\'s Next',
      body: 'At week {w}, we\'re at our booking cutoff for maternity sessions. But newborn portraits in the first 5–14 days are some of our most breathtaking work — sleepy, curled, completely new. Reserve your spot now so we\'re ready the moment baby arrives.',
      isNB: true
    },
    newborn:{
      lbl:  'Reserve Your Newborn Session Before Baby Arrives',
      body: 'Newborn sessions must be booked before baby arrives so we can hold your due date and be on-call the moment you\'re ready. Days 5–14 are the magic window — curly, sleepy, brand-new.',
      isNB: true
    },
    'default':{
      lbl:  'Find Out Exactly Where You Stand',
      body: 'Every client who\'s loved her maternity experience had one thing in common — she reached out before her preferred dates were gone. First pick of sessions, the full gown collection, hair and makeup included, and every detail handled from there. Take the quiz above to see your exact window and what\'s still available.',
      isNB: false
    }
  };

  /* ── Helpers ─────────────────────────────────────────────────── */
  function $id(id){return document.getElementById(id);}
  function pageSearch(){
    try{var s=window.parent.location.search;if(s&&s.length>1)return s;}catch(e){}
    return window.location.search;
  }
  function makeCta(cls,text,href){
    var a=document.createElement('a');
    a.className='tws-road__cta'+( cls?' '+cls:'');
    a.textContent=text; a.href=href;
    a.style.setProperty('color','#fff','important');
    a.style.setProperty('-webkit-text-fill-color','#fff','important');
    return a;
  }

  /* ── Opt-in data store ──────────────────────────────────────── */
  window._twsOptinData = {};

  /* ── Main render ─────────────────────────────────────────────── */
  function render(q){
    var week=q.week, status=q.status, type=q.type,
        duedate=q.duedate, winParam=q.window, bookby=q.bookby,
        wl=week?'Week '+week:'Currently',
        wf=windowStr(duedate,winParam)||(winParam?'Weeks '+winParam:'Weeks 28\u201332'),
        bf=bookby&&bookby!=='Today'?'Book by '+bookby:'Coming Up';

    /* ── v8.4: determine if this is a default (no personalisation) state ── */
    var isDefault = (!status || status === 'default') && !week && !duedate && !q.package;

    /* ── Show/hide roadmap and section gap based on personalisation ── */
    var roadEl  = $id('tws-road');
    var gapEl   = $id('tws-section-gap');
    if(roadEl)  roadEl.style.display  = isDefault ? 'none' : '';
    if(gapEl)   gapEl.style.display   = isDefault ? 'none' : '';

    /* --- HERO --- */
    var typeMap=HERO[type]||HERO.maternity;
    var u=typeMap[status]||typeMap['default'];
    var spotsInfo=(type!=='newborn')?getSpotsInfo(week,duedate,winParam):null;

    /* ── blackout_note guard ── */
    var isBlackoutRouted = !!(q.blackout_note);
    var blackoutMonth    = '';
    if(isBlackoutRouted){
      if(q.blackout_note === 'book_may')    blackoutMonth = 'May';
      if(q.blackout_note === 'book_august') blackoutMonth = 'August';
    }

    if(spotsInfo && spotsInfo.blackout && !isBlackoutRouted){
      var blackoutDest='https://twowildsoulsphotography.com/detroit-maternity-photographer-ads-custom?blackout=1';
      try{ window.top.location.href=blackoutDest; }catch(e){ window.location.href=blackoutDest; }
      return;
    }

    var tier=spotsInfo?WEEK_TIERS[spotsInfo.spots]:null;

    var isEarly=(status==='early');
    var effectiveTier=(!isEarly&&!isDefault&&tier)?tier:null;

    $id('tws-eyebrow').textContent  = effectiveTier?effectiveTier.ey:u.ey;
    $id('tws-headline').innerHTML   = (effectiveTier?effectiveTier.hl:u.hl).replace(/{w}/g,week||'').replace(/{win}/g,wf);
    $id('tws-sub').textContent      = (effectiveTier?effectiveTier.sub:u.sub).replace(/{w}/g,week||'').replace(/{win}/g,wf);

    /* ── blackout override ── */
    if(isBlackoutRouted && blackoutMonth){
      $id('tws-eyebrow').textContent = 'Maternity Photography · Metro Detroit';
      $id('tws-headline').innerHTML  = '<em>' + blackoutMonth + '</em> Sessions — You\'re All Set';
      $id('tws-sub').textContent     = 'We\'re fully booked in June and July, but ' + blackoutMonth + ' still has availability. Everything is included — pro hair and makeup, designer gowns, fully guided. Let\'s get your date secured before it goes.';
    }

    var badgeEl=$id('tws-badge');
    var badgeText, badgeUc;
    if(isBlackoutRouted){
      badgeText = blackoutMonth ? blackoutMonth + ' Availability — Limited Spots' : 'Limited Availability';
      badgeUc   = 'u-open';
    } else if(isDefault || isEarly){
      badgeText = u.badge || 'Sessions Available';
      badgeUc   = u.uc || 'u-soft';
    } else {
      badgeText = effectiveTier ? effectiveTier.badge : (spotsInfo ? spotsInfo.spots+' Session'+(spotsInfo.spots!==1?'s':'')+' Available' : (u.badge||''));
      badgeUc   = effectiveTier ? effectiveTier.uc : (spotsInfo ? spotsInfo.uc : u.uc||'u-soft');
    }
    badgeEl.textContent=badgeText||'';
    badgeEl.className='tws-hero__badge '+badgeUc;
    /* Hide badge in default state — quiz CTA does all the work */
    badgeEl.style.display=(isDefault||!badgeText)?'none':'inline-block';

    /* Spots bar — hide for early/default/blackout-routed */
    if(spotsInfo && !isEarly && !isDefault && !isBlackoutRouted){
      var spotsEl=$id('tws-spots'), countEl=$id('tws-spots-count'), pipsEl=$id('tws-pips');
      spotsEl.style.display='block';
      countEl.textContent=spotsInfo.label; countEl.className='tws-hero__spots-count '+spotsInfo.sc;
      pipsEl.innerHTML='';
      for(var i=0;i<spotsInfo.total;i++){
        var pip=document.createElement('div');
        pip.className='tws-hero__pip'+(i<spotsInfo.spots?' filled '+spotsInfo.pip:'');
        pip.style.animationDelay=(0.32+i*.055)+'s';
        pipsEl.appendChild(pip);
      }
    }

    if(bookby&&type!=='newborn'&&!isDefault){
      var byEl=$id('tws-bookby'), isToday=(bookby==='Today');
      if(!isToday){var d=new Date(bookby),now=new Date();now.setHours(0,0,0,0);if(!isNaN(d)&&d<now)isToday=true;}
      byEl.innerHTML=isToday?'Confirm availability <strong>today</strong>':'Book by <strong>'+bookby+'</strong> to guarantee your date.';
      byEl.style.display='block';
    }

    if(u.nudge&&!isDefault){var nudgeEl=$id('tws-nudge');nudgeEl.textContent=u.nudge;nudgeEl.style.display='block';}

    var pkgKey=q.package;
    if(!pkgKey&&!isDefault){
      var st=(q.style||'').toLowerCase(), se=(q.setting||'').toLowerCase();
      if(st==='momonly'||st==='mom_only'||st==='solo'||st==='justmom'||st==='just_mom') pkgKey='portraits';
      else if(st==='full'||se==='both'||se==='outdoor'||se==='outdoors') pkgKey='whiteGlove';
    }
    var pkg=PKGS[pkgKey], pg='';
    try{pg=window.parent.location.pathname+window.parent.location.search;}catch(e){}
    pg=pg||window.location.pathname+window.location.search;

    var ctaEl=$id('tws-cta'), pkgEl=$id('tws-pkg'), optinEl=$id('tws-optin');
    var quizTrustEl=$id('tws-quiz-trust');

    var oldNb=$id('tws-hero-nb');if(oldNb)oldNb.parentNode.removeChild(oldNb);

    var weekNum=parseInt(week,10);
    var showOptin=!isNaN(weekNum)&&weekNum<14&&type!=='newborn';

    /* ── v8.4: default state — quiz CTA only ── */
    if(isDefault){
      if(quizTrustEl) quizTrustEl.style.display='flex';
      if(optinEl) optinEl.style.display='none';
      pkgEl.style.display='none';
      ctaEl.textContent='Find Out Now →';
      ctaEl.className='tws-hero__cta';
      ctaEl.href='https://moments.twowildsoulsphotography.com/?start=1';
      ctaEl.setAttribute('target','_blank');
      ctaEl.setAttribute('rel','noopener');
      ctaEl.style.display='';
      $id('tws-sub').style.display='';
      return; /* nothing else to render when default */
    }

    /* ── All personalised states below ── */
    if(quizTrustEl) quizTrustEl.style.display='none';
    ctaEl.removeAttribute('target');

    if(showOptin){
      var optinBody = optinEl.querySelector('.tws-optin__body');
      if(optinBody){
        optinBody.textContent = optinBody.textContent.replace('{w}', week);
      }

      var evergreenPayload = {
        type:    type || 'maternity',
        package: pkgKey || '',
        duedate: duedate || ''
      };
      var evergreenUrl = (function(){
        try{
          var base = 'https://twowildsoulsphotography.com/personalized-maternity-results';
          return base + '?d=' + btoa(JSON.stringify(evergreenPayload));
        }catch(e){ return ''; }
      })();

      window._twsOptinData = {
        week:        week,
        status:      status,
        duedate:     duedate,
        package:     pkgKey || '',
        resultUrl:   evergreenUrl
      };

      var OPTIN_PRICES={portraits:'$490',whiteGlove:'$1,290'};
      var pillEl=$id('tws-optin-pill'), pillTxt=$id('tws-optin-pill-text');
      if(pillEl&&pillTxt){
        var pkgPrice=OPTIN_PRICES[pkgKey];
        if(pkgPrice&&PKGS[pkgKey]){
          pillTxt.textContent=PKGS[pkgKey].name+' from '+pkgPrice+' · See full pricing';
        } else {
          pillTxt.textContent='Sessions from $490 · See full pricing';
        }
        pillEl.href=pg+'#pricing';
      }

      var formEl=$id('tws-optin-form'), successEl=$id('tws-optin-success');
      if(formEl) formEl.style.display='';
      if(successEl) successEl.style.display='none';

      ctaEl.style.display='none';
      pkgEl.style.display='none';
      optinEl.style.display='block';
      $id('tws-sub').style.display='';
      $id('tws-badge').style.display='none';

    } else {
      if(optinEl) optinEl.style.display='none';
      $id('tws-sub').style.display='';

      if(pkg&&type!=='newborn'){
        ctaEl.style.display='none';
        $id('tws-pkg-icon').textContent=pkg.emoji;
        $id('tws-pkg-name').textContent=pkg.name;
        $id('tws-pkg-tagline').textContent=pkg.tagline;
        pkgEl.style.display='flex';
        if(u.ctaC) pkgEl.classList.add(u.ctaC);
        pkgEl.href=pg+'#pricing';
      } else {
        ctaEl.textContent=u.cta||'See Investment Details & Reserve Your Date';
        if(u.ctaC) ctaEl.classList.add(u.ctaC);
        ctaEl.href=u.isNB?'https://twowildsoulsphotography.com/detroit-newborn-photographer-ads':pg+'#pricing';
        ctaEl.style.display='';
        pkgEl.style.display='none';
        if(u.newborn){
          var nb=document.createElement('a');
          nb.id='tws-hero-nb'; nb.className='tws-hero__cta is-newborn';
          nb.textContent='Explore Newborn Sessions Instead';
          nb.href='https://twowildsoulsphotography.com/detroit-newborn-photographer-ads';
          nb.style.setProperty('text-decoration','none','important');
          ctaEl.parentNode.appendChild(nb);
        }
      }
    }

    /* --- ROADMAP --- */
    var mileKey=type==='newborn'?'newborn':(status||'default');
    var miles=(MILES[mileKey]||MILES['default']).map(function(m){
      return {
        when: m.when.replace(/{wl}/g,wl).replace(/{wf}/g,wf).replace(/{bf}/g,bf).replace(/{w}/g,week||''),
        state:m.state,
        title:m.title.replace(/{w}/g,week||''),
        body: m.body.replace(/{w}/g,week||'')
      };
    });

    var tl=$id('tws-timeline'); tl.innerHTML='';
    miles.forEach(function(m,i){
      var last=i===miles.length-1;
      var dc='tws-road__dot'+(m.state==='done'?' done':m.state==='active'?' active':m.state==='warn'?' warn':'');
      var wc='tws-road__when'+(m.state==='active'?' active':m.state==='warn'?' warn':'');
      var mc='tws-road__mile'+(m.state==='active'?' is-now':m.state==='warn'?' is-urgent':'');
      var row=document.createElement('div'); row.className=mc;
      row.innerHTML='<div class="tws-road__dot-wrap"><div class="'+dc+'"></div>'+(last?'':'<div class="tws-road__dot-line"></div>')+'</div><div class="tws-road__content"><span class="'+wc+'">'+m.when+'</span><h3 class="tws-road__title">'+m.title+'</h3><p class="tws-road__body">'+m.body+'</p></div>';
      tl.appendChild(row);
    });

    var expKey=type==='newborn'?'newborn':(status||'default');
    var exp=EXP[expKey]||EXP['default'];
    var expEl=$id('tws-exp');
    $id('tws-exp-label').textContent=exp.lbl;
    $id('tws-exp-body').textContent=exp.body.replace(/{w}/g,week||'').replace(/{wf}/g,wf);
    expEl.querySelectorAll('.tws-road__cta').forEach(function(b){b.parentNode.removeChild(b);});
    var urgent=(status==='urgent'||status==='late'||status==='pastWindow'||type==='newborn');
    if(urgent) expEl.classList.add('warn'); else expEl.classList.remove('warn');

    /* ── blackout override for excerpt ── */
    if(isBlackoutRouted && blackoutMonth){
      $id('tws-exp-label').textContent = blackoutMonth + ' Sessions — Reserve Before It Fills';
      $id('tws-exp-body').textContent  = 'We\'re fully booked in June and July, but ' + blackoutMonth + ' still has a few sessions available. Everything is included — pro hair and makeup, our full designer gown collection, fully guided from start to finish. Securing your date now guarantees first pick of what\'s left.';
      expEl.classList.remove('warn');
    }

    if(exp.isNB){
      expEl.appendChild(makeCta('newborn','Reserve Your Newborn Session →','https://twowildsoulsphotography.com/detroit-newborn-photographer-ads'));
    } else if(!isBlackoutRouted && (status==='urgent'||status==='pastWindow')){
      expEl.appendChild(makeCta('','See Maternity Pricing',pg+'#pricing'));
      var nb2=makeCta('newborn','Reserve Your Newborn Session →','https://twowildsoulsphotography.com/detroit-newborn-photographer-ads');
      nb2.style.marginTop='8px'; expEl.appendChild(nb2);
    } else if(pkg){
      var pkgCard=document.createElement('a');
      pkgCard.className='tws-road__pkg';
      pkgCard.href=pg+'#pricing';
      pkgCard.innerHTML=
        '<span class="tws-road__pkg__icon">'+pkg.emoji+'</span>'+
        '<span class="tws-road__pkg__body">'+
          '<span class="tws-road__pkg__label">Your Recommended Experience</span>'+
          '<span class="tws-road__pkg__name">'+pkg.name+'</span>'+
          '<span class="tws-road__pkg__tagline">'+pkg.tagline+'</span>'+
          '<span class="tws-road__pkg__pricing">See pricing ›</span>'+
        '</span>'+
        '<span class="tws-road__pkg__arrow">›</span>';
      pkgCard.style.setProperty('color','#fff','important');
      pkgCard.style.setProperty('-webkit-text-fill-color','#fff','important');
      expEl.appendChild(pkgCard);
    } else {
      expEl.appendChild(makeCta('','See Investment Details & Reserve Your Date',pg+'#pricing'));
    }
  }

  /* ── Bootstrap ──────────────────────────────────────────────────── */
  function init(search){ render(decode(search)); }

  document.addEventListener('click', function(e){
    if(e.target && e.target.id === 'tws-optin-btn') twsOptinSubmit();
  });

  var s=pageSearch();
  if(s&&s.length>1){ init(s); return; }
  window.addEventListener('message',function(e){ if(e.data&&e.data.twsSearch) init(e.data.twsSearch); });
  var ref=document.referrer||'';
  if(ref.indexOf('?')>-1){ init('?'+ref.split('?')[1]); return; }
  init('?type=maternity&status=default');

}();
</script>

