}
.tws-optin__fields { display:flex; flex-direction:column; align-items:stretch; gap:8px; margin-bottom:12px; }
.tws-optin__field {
  display: block;
  width: 100%;
  height: 44px;
  padding: 0 14px !important;
  margin: 0;
  border: 1.5px solid var(--tws-border);
  border-radius: 2px;
  background: #fff;
  color: var(--tws-forest);
  font-family: 'DM Sans', sans-serif !important;
  font-size: 13px !important;
  font-weight: 300 !important;
  line-height: normal;
  vertical-align: middle;
  outline: none;
  box-sizing: border-box;
  -webkit-appearance: none;
  -moz-appearance: none;
  appearance: none;
  transition: border-color .18s;
  -webkit-text-size-adjust: 100%;
  align-self: stretch;
}
.tws-optin__field:focus { border-color: var(--tws-sage); }
.tws-optin__field::placeholder { color: #bbb; }

.tws-optin__submit {
  width:100%; background:var(--tws-gold); color:#1a1a18;
  font-family:'DM Sans',sans-serif; font-size:9.5px; font-weight:500;
  letter-spacing:.22em; text-transform:uppercase; padding:14px;
  border:none; border-radius:2px; cursor:pointer;
  transition:background .2s,transform .18s;
  box-shadow:0 4px 16px rgba(199,178,122,.3);
}
.tws-optin__submit:hover { background:#b8a066; transform:translateY(-1px); }
.tws-optin__submit:disabled { opacity:.6; cursor:not-allowed; transform:none; }
.tws-optin__trust {
  font-size:10.5px; font-weight:300; color:#aaa;
  text-align:center; margin-top:10px;
}
.tws-optin__success {
  display:none; text-align:center; padding:8px 0;
}
.tws-optin__success-icon { font-size:28px; display:block; margin-bottom:8px; }
.tws-optin__success-title {
  font-family:'Playfair Display',Georgia,serif; font-size:18px;
  font-weight:400; color:var(--tws-forest); margin:0 0 6px;
}
.tws-optin__success-body {
  font-size:13px; font-weight:300; color:var(--tws-muted); line-height:1.6; margin:0;
}
.tws-optin__error {
  font-size:11px; color:var(--tws-urgent); margin-top:8px; display:none;
}

/* ── Divider between sections ───────────────────────────────────── */
.tws-section-gap { height: 48px; }

/* ── Roadmap ─────────────────────────────────────────────────────── */
.tws-road {
  max-width:860px; margin:0 auto;
  padding:8px 20px 56px;
  font-family:'DM Sans',sans-serif;
}
.tws-road__label {
  font-size:9px; font-weight:500; letter-spacing:.28em; text-transform:uppercase;
  color:var(--tws-gold); text-align:center; margin-bottom:36px; display:block;
}
.tws-road__timeline { position:relative; margin-bottom:44px; }
.tws-road__timeline::before {
  content:''; position:absolute; left:26px; top:8px; bottom:8px; width:1px;
  background:linear-gradient(to bottom,var(--tws-gold),var(--tws-border),transparent);
}
.tws-road__mile {
  display:flex; gap:24px; position:relative;
  opacity:0; transform:translateY(14px);
  animation:twsSlide .5s ease forwards;
}
.tws-road__mile:nth-child(1){animation-delay:.08s} .tws-road__mile:nth-child(2){animation-delay:.18s}
.tws-road__mile:nth-child(3){animation-delay:.28s} .tws-road__mile:nth-child(4){animation-delay:.38s}
.tws-road__mile:nth-child(5){animation-delay:.46s}
.tws-road__dot-wrap { flex:0 0 52px; display:flex; flex-direction:column; align-items:center; padding-top:3px; }
.tws-road__dot {
  width:14px; height:14px; border-radius:50%; border:2px solid var(--tws-border);
  background:var(--tws-cream); flex-shrink:0; position:relative; z-index:1;
}
.tws-road__dot.done   { background:var(--tws-sage);   border-color:var(--tws-sage); }
.tws-road__dot.active { background:var(--tws-gold);   border-color:var(--tws-gold); box-shadow:0 0 0 4px rgba(199,178,122,.2); }
.tws-road__dot.warn   { background:var(--tws-urgent); border-color:var(--tws-urgent); box-shadow:0 0 0 4px rgba(176,48,16,.15); }
.tws-road__dot-line   { width:1px; flex:1; min-height:28px; background:var(--tws-border); margin-top:6px; }
.tws-road__mile:last-child .tws-road__dot-line { display:none; }
.tws-road__content { flex:1; padding-bottom:28px; }
.tws-road__mile:last-child .tws-road__content { padding-bottom:0; }
.tws-road__when { font-size:9px; font-weight:500; letter-spacing:.22em; text-transform:uppercase; color:var(--tws-muted); margin-bottom:4px; display:block; }
.tws-road__when.active { color:var(--tws-gold); }
.tws-road__when.warn   { color:var(--tws-urgent); }
.tws-road__title { font-family:'Playfair Display',Georgia,serif; font-size:19px; font-weight:400; color:var(--tws-forest); line-height:1.25; margin-bottom:6px; }
.tws-road__title em { font-style:italic; color:var(--tws-sage); }
.tws-road__body { font-size:13px; font-weight:300; color:var(--tws-muted); line-height:1.7; margin:0; }
.tws-road__mile.is-now .tws-road__content {
  background:var(--tws-warm); border:1.5px solid var(--tws-gold);
  border-radius:3px; padding:18px 20px; margin-bottom:28px; position:relative;
}
.tws-road__mile.is-now .tws-road__content::before {
  content:'You Are Here'; position:absolute; top:-9px; left:16px;
  background:var(--tws-gold); color:#fff; font-size:7.5px; font-weight:600;
  letter-spacing:.18em; text-transform:uppercase; padding:2px 8px; border-radius:20px;
}
.tws-road__mile.is-urgent .tws-road__content {
  background:#fdf0ec; border:1.5px solid #e07050;
  border-radius:3px; padding:18px 20px; margin-bottom:28px; position:relative;
}
.tws-road__mile.is-urgent .tws-road__content::before {
  content:'Act Now'; position:absolute; top:-9px; left:16px;
  background:var(--tws-urgent); color:#fff; font-size:7.5px; font-weight:600;
  letter-spacing:.18em; text-transform:uppercase; padding:2px 8px; border-radius:20px;
}

/* Excerpt block */
.tws-road__exp {
  border-left:3px solid var(--tws-green); background:var(--tws-warm);
