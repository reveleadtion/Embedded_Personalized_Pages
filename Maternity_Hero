<script>
var TWS_KL_KEY     = 'WgMSBs';
var TWS_KL_LIST_ID = 'V3bUGq';

function twsFormatPhone(raw){
  var digits = raw.replace(/\D/g, '');
  if(digits.length === 11 && digits.charAt(0) === '1') return '+' + digits;
  if(digits.length === 10) return '+1' + digits;
  return '+' + digits;
}

function twsCalcWindowDate(duedateStr){
  if(!duedateStr) return '';
  var d=new Date(duedateStr);
  if(isNaN(d.getTime())) return '';
  d.setDate(d.getDate()-182);
  return d.toISOString().split('T')[0];
}

function twsOptinSubmit(){
  var name  = (document.getElementById('tws-optin-name') ||{}).value||'';
  var email = (document.getElementById('tws-optin-email')||{}).value||'';
  var phone = (document.getElementById('tws-optin-phone')||{}).value||'';
  var errEl = document.getElementById('tws-optin-error');
  var btn   = document.getElementById('tws-optin-btn');

  if(errEl) errEl.style.display='none';
  if(!name.trim()){ if(errEl){errEl.textContent='Please enter your first name.';errEl.style.display='block';} return; }
  if(!email.trim()||email.indexOf('@')<0){ if(errEl){errEl.textContent='Please enter a valid email.';errEl.style.display='block';} return; }
  if(!phone.trim()){ if(errEl){errEl.textContent='Please enter your phone number.';errEl.style.display='block';} return; }

  if(btn){ btn.disabled=true; btn.textContent='Sending…'; }

  var d = window._twsOptinData || {};
  var windowOpensDate = twsCalcWindowDate(d.duedate || '');
  var resultUrl = d.resultUrl || '';

  var BASE  = 'https://a.klaviyo.com/client/';
  var HEADS = {'Content-Type':'application/json','revision':'2023-12-15'};

  var profileAttrs = {
    email:        email.trim(),
    first_name:   name.trim(),
    phone_number: twsFormatPhone(phone),
    properties: {
      tws_due_date:          d.duedate || '',
      tws_week_at_signup:    parseInt(d.week, 10) || 0,
      tws_quiz_status:       d.status || 'early',
      tws_quiz_package:      d.package || '',
      tws_window_opens_date: windowOpensDate,
      tws_source:            'early_optin_embed',
      tws_result_url:        resultUrl
    }
  };

  var subPayload = {data:{type:'subscription',attributes:{
    custom_source: 'early_optin_embed',
    profile:       {data:{type:'profile',attributes:profileAttrs}}
  },relationships:{list:{data:{type:'list',id:TWS_KL_LIST_ID}}}}};

  function showSuccess(){
    var f = document.getElementById('tws-optin-form');
    var s = document.getElementById('tws-optin-success');
    if(f) f.style.display = 'none';
    if(s) s.style.display = 'block';
    try{
      window.parent.postMessage({
        type:      'tws-pixel-event',
        eventName: 'EarlyOptinLead',
        params: {
          content_name:     'Early Optin Embed',
          content_category: 'early',
          tws_source:       'early_optin_embed',
          tws_week:    (window._twsOptinData && window._twsOptinData.week)    ? String(window._twsOptinData.week)    : '',
          tws_package: (window._twsOptinData && window._twsOptinData.package) ? window._twsOptinData.package         : ''
        }
      }, '*');
    }catch(x){}
  }

  function showError(){
    if(btn){ btn.disabled=false; btn.textContent='Send Me the Guide'; }
    if(errEl){ errEl.textContent='Something went wrong — please try again.'; errEl.style.display='block'; }
  }

  fetch(BASE + 'subscriptions/?company_id=' + TWS_KL_KEY, {
    method:  'POST',
    headers: HEADS,
    body:    JSON.stringify(subPayload)
  })
  .then(function(r){
    return r.text().then(function(body){
      if(!r.ok && r.status !== 202) throw new Error('sub ' + r.status);
      showSuccess();
    });
  })
  .catch(function(err){
    showError();
  });
}
</script>
