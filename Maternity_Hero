  /* ── Week calculator ────────────────────────────────────────── */
  function calcWeekFromDueDate(dueDateStr){
    if(!dueDateStr) return null;
    var due=new Date(dueDateStr);
    if(isNaN(due.getTime())) return null;
    var MS_PER_WEEK = 7*24*60*60*1000;
    var conception  = new Date(due.getTime() - 280*24*60*60*1000);
    var week        = Math.floor((Date.now() - conception.getTime()) / MS_PER_WEEK);
    return Math.min(Math.max(week, 1), 42);
  }

  function calcStatusFromWeek(week, type){
    if(!week) return 'default';
    var w = parseInt(week, 10);
    if(isNaN(w)) return 'default';
    if(type === 'newborn') return 'newborn';
    if(w < 14)  return 'early';
    if(w <= 27) return 'inWindow';
    if(w <= 29) return 'pastWindow';
    if(w <= 32) return 'urgent';
    return 'late';
  }

