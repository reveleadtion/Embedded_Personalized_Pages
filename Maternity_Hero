  var STATUS_WORDS = ['early','inWindow','pastWindow','urgent','late','newborn','default'];

  /* ── Decoder ────────────────────────────────────────────────── */
  function decode(search){
    var FB={week:'',status:'default',window:'',bookby:'',type:'maternity',duedate:'',package:'',style:'',setting:'',blackout_note:''};
    try{
      var raw=new URLSearchParams(search).get('d');
      if(raw){
        var pad=raw.replace(/-/g,'+').replace(/_/g,'/');
        while(pad.length%4) pad+='=';
        var str;
        try{ str=new TextDecoder().decode(Uint8Array.from(atob(pad),function(c){return c.charCodeAt(0);})); }
        catch(e){ str=decodeURIComponent(escape(atob(pad))); }
        var obj;
        try{ obj=JSON.parse(str); }
        catch(e){
          var s=str.replace(/,\s*"[^"]*$/,'').replace(/,\s*$/,'')+'}';
          obj=JSON.parse(s);
        }
        var merged = Object.assign({},FB,obj);

        if(merged.style && STATUS_WORDS.indexOf(merged.style.toLowerCase()) > -1){
          merged.style = '';
        }

        if(merged.duedate){
          var liveWeek = calcWeekFromDueDate(merged.duedate);
          if(liveWeek !== null){
            merged.week   = String(liveWeek);
            merged.status = calcStatusFromWeek(liveWeek, merged.type);
          }
        } else if(merged.week){
          merged.status = calcStatusFromWeek(parseInt(merged.week, 10), merged.type);
        }

        return merged;
      }
    }catch(e){ console.warn('[TWS] decode failed',e); }

