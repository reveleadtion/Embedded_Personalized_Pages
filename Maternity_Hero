  box-shadow:0 4px 20px rgba(63,68,56,.22);
}
.tws-hero__pkg:hover { background:var(--tws-sage); transform:translateY(-1px); }
.tws-hero__pkg.u-urgent { background:var(--tws-urgent); }
.tws-hero__pkg.u-urgent:hover { background:#8b2008; }
.tws-hero__pkg__icon { font-size:24px; flex-shrink:0; line-height:1; }
.tws-hero__pkg__body { flex:1; min-width:0; }
.tws-hero__pkg__label {
  font-size:8px; font-weight:500; letter-spacing:.22em; text-transform:uppercase;
  color:rgba(255,255,255,.6); display:block; margin-bottom:3px;
}
.tws-hero__pkg__name {
  font-family:'Playfair Display',Georgia,serif; font-size:16px;
  font-weight:400; font-style:italic; color:#fff; display:block;
  line-height:1.2; margin-bottom:2px;
}
.tws-hero__pkg__tagline {
  font-size:10px; font-weight:300; color:rgba(255,255,255,.65);
  display:block; margin-bottom:5px;
}
.tws-hero__pkg__pricing {
  display:inline-block; font-size:8.5px; font-weight:500; letter-spacing:.14em;
  text-transform:uppercase; color:rgba(255,255,255,.55);
  border-top:1px solid rgba(255,255,255,.15); padding-top:5px; margin-top:1px;
}
.tws-hero__pkg__arrow { font-size:20px; color:rgba(255,255,255,.7); flex-shrink:0; }

/* ── Early opt-in card ──────────────────────────────────────────── */
.tws-optin {
  display:none; background:var(--tws-warm); border:1.5px solid var(--tws-gold);
  border-radius:4px; padding:22px 24px; text-align:left;
  animation:twsFade .55s .34s both;
}
.tws-optin__pricing-pill {
  display:inline-flex; align-items:center; gap:6px;
  font-size:10px; font-weight:500; letter-spacing:.08em;
