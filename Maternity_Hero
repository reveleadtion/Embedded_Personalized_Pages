<!-- ═══════════════════════════════════════════════════════════════
     TWO WILD SOULS — Combined Hero + Roadmap Embed  v8.4
     Changes from v8.3:
       1. Default state (no quiz params) now leads with quiz CTA.
          Hero headline/sub replaced with quiz-forward copy.
          CTA button links directly to quiz (new tab).
       2. Roadmap section hidden in default state — shown only
          after quiz personalisation params are present.
       3. Quiz card (tws-quiz-card) removed — hero handles it.
       4. All personalised states (early, inWindow, pastWindow,
          urgent, late, newborn) unchanged.
     ═══════════════════════════════════════════════════════════════ -->
<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&family=DM+Sans:wght@300;400;500&display=swap');

:root {
  --tws-forest: #2E2F2C; --tws-green:  #3F4438; --tws-sage:   #7C8A5A;
  --tws-gold:   #C7B27A; --tws-cream:  #FAFAF7; --tws-warm:   #F0EDE8;
  --tws-muted:  #6B6E6A; --tws-border: #DDD9D3;
  --tws-urgent: #b03010; --tws-warn:   #bf5f18;
}

.tws * { box-sizing: border-box; }
.tws a { text-decoration: none !important; }
@keyframes twsFade  { from { opacity:0; transform:translateY(8px)  } to { opacity:1; transform:none } }
@keyframes twsSlide { from { opacity:0; transform:translateY(14px) } to { opacity:1; transform:none } }

/* ── Hero ───────────────────────────────────────────────────────── */
.tws-hero {
  font-family: 'DM Sans', sans-serif;
  text-align: center;
  padding: 32px 20px 28px;
  max-width: 620px;
  margin: 0 auto;
}
.tws-hero__eyebrow {
  font-size: 9px; font-weight: 500; letter-spacing: .3em; text-transform: uppercase;
  color: var(--tws-gold); margin-bottom: 12px; display: block;
  animation: twsFade .55s .05s both;
}
.tws-hero__headline {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: clamp(26px,6vw,42px); font-weight: 400; line-height: 1.2;
  color: var(--tws-forest); margin-bottom: 6px; letter-spacing: -.01em;
  animation: twsFade .55s .10s both;
}
.tws-hero__headline em { font-style: italic; color: var(--tws-sage); }
.tws-hero__divider {
  width: 32px; height: 1px; background: var(--tws-gold);
  margin: 10px auto 14px; opacity: .5;
  animation: twsFade .55s .15s both;
}
.tws-hero__sub {
  font-size: 14px; font-weight: 300; line-height: 1.6;
  color: var(--tws-muted); margin: 0 0 14px;
  animation: twsFade .55s .18s both;
}
.tws-hero__badge {
  display: none; font-size: 9.5px; font-weight: 600; letter-spacing: .18em;
  text-transform: uppercase; padding: 6px 16px; border-radius: 40px;
  margin-bottom: 8px; border: 1.5px solid currentColor;
  animation: twsFade .55s .22s both;
}
.tws-hero__badge.u-urgent { color:var(--tws-urgent); background:#fdf0ec; border-color:#e07050; }
.tws-hero__badge.u-warning { color:var(--tws-warn);   background:#fdf3ec; border-color:#e8a070; }
.tws-hero__badge.u-open   { color:var(--tws-sage);   background:#eef2e8; border-color:#8aaa60; }
.tws-hero__badge.u-soft   { color:var(--tws-muted);  background:var(--tws-warm); border-color:#c8c5be; }

/* Spots bar */
.tws-hero__spots { display:none; margin:0 auto 16px; max-width:380px; animation:twsFade .55s .26s both; }
.tws-hero__spots-label {
  font-size:10px; font-weight:500; letter-spacing:.15em; text-transform:uppercase;
  margin-bottom:8px; display:flex; justify-content:space-between; align-items:center;
}
.tws-hero__spots-label span:first-child { color:var(--tws-muted); }
.tws-hero__spots-count { font-size:12px; font-weight:600; letter-spacing:.05em; }
.tws-hero__spots-count.s1 { color:var(--tws-urgent); }
.tws-hero__spots-count.s2 { color:#c0420e; }
.tws-hero__spots-count.s3 { color:var(--tws-warn); }
.tws-hero__spots-count.s4 { color:#8a9a50; }
.tws-hero__spots-count.s6 { color:var(--tws-sage); }
.tws-hero__pips { display:flex; gap:5px; justify-content:center; }
.tws-hero__pip {
  flex:1; height:6px; border-radius:3px; background:#e8e5de;
  transition: background .4s ease, transform .3s ease;
}
.tws-hero__pip.filled.p-urgent     { background:var(--tws-urgent); }
.tws-hero__pip.filled.p-warn-hot   { background:#c0420e; }
.tws-hero__pip.filled.p-warn       { background:var(--tws-warn); }
.tws-hero__pip.filled.p-mild       { background:#8a9a50; }
.tws-hero__pip.filled.p-open       { background:var(--tws-sage); }

.tws-hero__bookby {
  font-size:12px; font-weight:300; color:#999; margin:0 0 14px; display:none;
  animation: twsFade .55s .28s both;
}
.tws-hero__bookby strong { color:var(--tws-urgent); font-weight:500; }
.tws-hero__nudge {
  display:none; font-size:11px; font-weight:300; font-style:italic;
  color:#aaa; margin:8px 0 0;
}

/* Hero CTAs */
.tws-hero__cta-wrap {
  margin: 18px auto 0; display:flex; flex-direction:column;
  align-items:stretch; gap:10px; max-width:420px;
  animation: twsFade .55s .34s both;
}
.tws-hero__cta {
  display:inline-block; background:var(--tws-green) !important;
  color:#fff !important; -webkit-text-fill-color:#fff !important;
  font-family:'DM Sans',sans-serif !important; font-size:9.5px !important;
  font-weight:500 !important; letter-spacing:.22em !important;
  text-transform:uppercase !important; padding:15px 40px !important;
  border-radius:2px !important; cursor:pointer !important;
  transition:background .2s,transform .18s !important;
  box-shadow:0 4px 20px rgba(63,68,56,.22) !important;
  width:100% !important;
}
.tws-hero__cta:hover { background:var(--tws-sage) !important; transform:translateY(-1px) !important; }
.tws-hero__cta.u-urgent  { background:var(--tws-urgent) !important; }
.tws-hero__cta.u-urgent:hover { background:#8b2008 !important; }
.tws-hero__cta.is-newborn { background:#c94b4b !important; }
.tws-hero__cta.is-newborn:hover { background:#a03838 !important; }

/* Default quiz trust pills */
.tws-hero__quiz-trust {
  display:none;
  justify-content:center; gap:20px; flex-wrap:wrap;
  margin-top:12px;
  animation: twsFade .55s .42s both;
}
.tws-hero__quiz-trust-pill {
  font-size:9.5px; font-weight:400; color:var(--tws-muted);
  display:flex; align-items:center; gap:6px;
}
.tws-hero__quiz-trust-pill::before {
  content:'✓'; font-size:10px; color:var(--tws-sage); font-weight:600;
}

/* Package card CTA */
.tws-hero__pkg {
  display:none; align-items:center; gap:12px;
  background:var(--tws-green); border-radius:4px; padding:14px 18px;
  color:#fff; cursor:pointer; text-align:left; width:100%;
