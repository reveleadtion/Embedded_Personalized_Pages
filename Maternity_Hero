}
.tws-road__cta:hover { background:var(--tws-sage) !important; transform:translateY(-1px) !important; }
.tws-road__cta.newborn { background:var(--tws-urgent) !important; box-shadow:0 4px 16px rgba(176,48,16,.2) !important; }
.tws-road__cta.newborn:hover { background:#8b2008 !important; }

/* Package card in roadmap exp block */
.tws-road__pkg {
  display:flex; align-items:center; gap:12px;
  background:var(--tws-green); border-radius:4px; padding:14px 18px;
  color:#fff; cursor:pointer; text-align:left; width:100%; max-width:420px;
  transition:background .2s,transform .18s,box-shadow .18s;
  box-shadow:0 4px 20px rgba(63,68,56,.22);
  text-decoration:none !important;
}
.tws-road__pkg:hover { background:var(--tws-sage); transform:translateY(-1px); }
.tws-road__pkg__icon { font-size:24px; flex-shrink:0; line-height:1; }
.tws-road__pkg__body { flex:1; min-width:0; }
.tws-road__pkg__label {
  font-size:8px; font-weight:500; letter-spacing:.22em; text-transform:uppercase;
  color:rgba(255,255,255,.6); display:block; margin-bottom:3px;
}
.tws-road__pkg__name {
  font-family:'Playfair Display',Georgia,serif; font-size:16px;
  font-weight:400; font-style:italic; color:#fff; display:block;
  line-height:1.2; margin-bottom:2px;
}
.tws-road__pkg__tagline {
  font-size:10px; font-weight:300; color:rgba(255,255,255,.65);
  display:block; margin-bottom:5px;
}
.tws-road__pkg__pricing {
  display:inline-block; font-size:8.5px; font-weight:500; letter-spacing:.14em;
  text-transform:uppercase; color:rgba(255,255,255,.55);
  border-top:1px solid rgba(255,255,255,.15); padding-top:5px; margin-top:1px;
}
.tws-road__pkg__arrow { font-size:20px; color:rgba(255,255,255,.7); flex-shrink:0; }

/* Included grid */
.tws-road__includes {
  display:grid; grid-template-columns:repeat(4,1fr); gap:1px;
  background:var(--tws-border); border:1px solid var(--tws-border);
  border-radius:3px; overflow:hidden; margin-top:40px;
}
.tws-road__inc-item { background:var(--tws-cream); padding:20px 14px; text-align:center; }
.tws-road__inc-icon  { font-size:20px; display:block; margin-bottom:8px; }
.tws-road__inc-title { font-family:'Playfair Display',Georgia,serif; font-size:13px; font-weight:400; color:var(--tws-forest); display:block; margin-bottom:4px; }
