<!-- TWO WILD SOULS — MATERNITY POPUP v6
     Changes from v5:
     - Removed 4-step preview list
     - Condensed card to single self-contained panel
     - Verbiage now matches quiz redirect page exactly
     - Feature pills: Pro Hair + Makeup · Designer Gowns · In-Studio & Outdoors · Fully Guided
     - Social proof: 5.0 · 67 Google reviews
     - CTA: "Get My Recommendation"
     - Subtitle: "Takes 20 seconds · No personal information required"
     - All tracking logic (fbclid/gclid, suppress, ribbon) unchanged

     TEST_MODE = true  → fires instantly, skips suppression
     TEST_MODE = false → 2 min delay, 7-day suppress (GO LIVE)

     MANUAL TRIGGER:
     - Set any Showit button URL to: javascript:twsOpen()
-->
<script>
(function(){

var TEST_MODE   = false;
var FLAG_KEY    = 'tws_maternity_flag';
var TIMER_KEY   = 'tws_maternity_timer_start';
var DISMISS_KEY = 'tws_popup_dismissed';
var DELAY_MS    = TEST_MODE ? 0 : 120000;
var SUPPRESS_MS = 7 * 24 * 60 * 60 * 1000;
var RIBBON_KEY  = 'tws_ribbon_active';
var QUIZ_URL    = 'https://moments.twowildsoulsphotography.com/';
var EXCLUDED    = [
  'detroit-maternity-photographer-ads',
  'personalized-maternity-results',
  'personalized-senior-results',
  'maternity-timing-calculator-when-to-take-maternity-photos',
  'contact-two-wild-souls-photography'
];

/* ── Page checks ── */
function isQualifyingMaternityPage(){
  var u    = window.location.href.toLowerCase();
  var path = window.location.pathname.toLowerCase().replace(/\/$/, '');
  for(var i = 0; i < EXCLUDED.length; i++){
    if(u.indexOf('/' + EXCLUDED[i]) !== -1) return false;
  }
  var patterns = ['maternity-photography','maternity-boudoir'];
  for(var p = 0; p < patterns.length; p++){
    if(path.indexOf(patterns[p]) !== -1) return true;
  }
  var slugs = [
    'what-to-wear-maternity-photos-detroit-style-guide',
    'the-best-time-to-take-maternity-photos-in-metro-detroit',
    'how-to-prepare-for-a-stunning-maternity-photoshoot-in-metro-detroit',
    'rochester-studio-maternity-photography-what-to-expect',
    'studio-vs-outdoor-maternity-photos-metro-detroit',
    'maternity-photo-poses-detroit',
    'top-metro-detroit-maternity-photo-session-locations',
    'stress-free-maternity-photography-metro-detroit',
    'what-to-wear-maternity-photoshoot-metro-detroit',
    'best-maternity-and-newborn-photoshoot-experience-in-metro-detroit',
    'royal-oak-michigan-newborn-and-maternity-photography',
    'bloomfield-hills-maternity-newborn-photography-timeless-portraits',
    'maternity-newborn-service-comparison',
    'top-10-baby-registry-items-for-2026',
    'pregnancy-maternity-must-haves-2026',
    'the-ultimate-checklist-for-first-time-parents',
    'capturing-the-magic-maternity-photos-that-truly-shine',
    'detroit-maternity-photos-guide',
    'metro-detroit-maternity-photo-inspiration-poses-outfits-locations',
    'maternity-photos-at-rochester-michigan',
    'maternity-guide-michigan',
    'maternity-transformations-two-wild-souls',
    'metro-detroit-moms-choose-two-wild-souls-maternity',
    'belle-isle-fountain-maternity-photos',
    'studio-maternity-session-in-royal-oak-mi',
    'novi-maternity-photographer-best-parks-studio-options',
    'michigan-winter-maternity-photoshoot-ideas-szg2w',
    'birmingham-michigan-maternity-boudoir-photography'
  ];
  for(var s = 0; s < slugs.length; s++){
    if(path.indexOf(slugs[s]) !== -1) return true;
  }
  return false;
}

function isExcludedPage(){
  var u=window.location.href.toLowerCase();
  for(var i=0;i<EXCLUDED.length;i++){ if(u.indexOf('/'+EXCLUDED[i])!==-1) return true; }
  return false;
}
function isDismissed(){
  if(TEST_MODE) return false;
  try{ var v=localStorage.getItem(DISMISS_KEY); return !!(v&&(Date.now()-parseInt(v))<SUPPRESS_MS); }catch(e){ return false; }
}
function setDismissed(){ try{ localStorage.setItem(DISMISS_KEY,Date.now().toString()); }catch(e){} }
function setFlag(){ try{ localStorage.setItem(FLAG_KEY,'1'); }catch(e){} }
function isFlagged(){ try{ return localStorage.getItem(FLAG_KEY)==='1'; }catch(e){ return false; } }
function getTimerStart(){ try{ var v=localStorage.getItem(TIMER_KEY); return v?parseInt(v):null; }catch(e){ return null; } }
function setTimerStart(){ try{ if(!localStorage.getItem(TIMER_KEY)) localStorage.setItem(TIMER_KEY,Date.now().toString()); }catch(e){} }
function clearTimer(){ try{ localStorage.removeItem(TIMER_KEY); }catch(e){} }
function setRibbonActive(){ try{ sessionStorage.setItem(RIBBON_KEY,'1'); }catch(e){} }
function clearRibbonActive(){ try{ sessionStorage.removeItem(RIBBON_KEY); }catch(e){} }
function isRibbonActive(){ try{ return sessionStorage.getItem(RIBBON_KEY)==='1'; }catch(e){ return false; } }
function timeElapsed(){ var s=getTimerStart(); return s?Date.now()-s:0; }

/* ── Styles ── */
function injectStyles(){
  if(document.getElementById('twsPopStyles6')) return;
  var s=document.createElement('style'); s.id='twsPopStyles6';
  s.textContent=[
    '@import url("https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap");',

    /* Overlay */
    '#twsPop{display:none;position:fixed;inset:0;background:rgba(30,31,28,0.72);z-index:99999;align-items:center;justify-content:center;padding:20px;backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);}',
    '#twsPop.open{display:flex;animation:twsOvIn 0.28s ease both;}',
    '@keyframes twsOvIn{from{opacity:0}to{opacity:1}}',

    /* Card */
    '#twsCard{',
      'position:relative;width:100%;max-width:420px;',
      'border-radius:12px;overflow:hidden;',
      'background:linear-gradient(160deg,#3F4438 0%,#4d5540 55%,#3a4035 100%);',
      'box-shadow:0 28px 80px rgba(20,22,18,0.55);',
      'animation:twsCardIn 0.34s cubic-bezier(0.34,1.1,0.64,1) both;',
    '}',
    '@keyframes twsCardIn{from{opacity:0;transform:translateY(24px) scale(0.95)}to{opacity:1;transform:none}}',

    /* Texture overlay on card */
    '#twsCard::before{content:"";position:absolute;inset:0;background:url("data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'0.025\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");pointer-events:none;z-index:0;}',

    /* Close */
    '#twsClose{position:absolute;top:13px;right:13px;z-index:10;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.18);border-radius:50%;width:28px;height:28px;font-size:12px;color:rgba(255,255,255,0.65);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.15s;font-family:sans-serif;}',
    '#twsClose:hover{background:rgba(255,255,255,0.2);color:#fff;}',

    /* Inner content */
    '#twsInner{position:relative;z-index:1;padding:36px 30px 28px;}',

    /* Eyebrow */
    '.tws-eyebrow{display:flex;align-items:center;gap:10px;margin-bottom:18px;}',
    '.tws-eyebrow-line{flex:1;height:1px;background:rgba(199,178,122,0.3);}',
    '.tws-eyebrow span{font-family:"DM Sans",sans-serif;font-size:9px;font-weight:500;letter-spacing:0.22em;text-transform:uppercase;color:rgba(199,178,122,0.75);white-space:nowrap;}',

    /* Spots badge */
    '.tws-spots{display:inline-flex;align-items:center;gap:6px;background:rgba(199,178,122,0.14);border:1px solid rgba(199,178,122,0.28);border-radius:20px;padding:4px 12px;margin-bottom:14px;}',
    '.tws-spots-dot{width:6px;height:6px;border-radius:50%;background:#C7B27A;animation:twsPulse 2s ease-in-out infinite;}',
    '@keyframes twsPulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.5;transform:scale(0.8)}}',
    '.tws-spots span{font-family:"DM Sans",sans-serif;font-size:9.5px;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;color:rgba(199,178,122,0.85);}',

    /* Headline */
    '#twsInner h2{font-family:"Cormorant Garamond",serif;font-size:30px;font-weight:300;line-height:1.15;color:#fff;margin-bottom:6px;}',
    '#twsInner h2 em{font-style:italic;color:#C7B27A;}',

    /* Subhead */
    '.tws-consult-label{font-family:"DM Sans",sans-serif;font-size:11px;font-weight:500;letter-spacing:0.18em;text-transform:uppercase;color:rgba(199,178,122,0.7);margin-bottom:16px;}',

    /* Body copy */
    '.tws-body{font-family:"DM Sans",sans-serif;font-size:12.5px;font-weight:300;color:rgba(255,255,255,0.65);line-height:1.65;margin-bottom:22px;}',
    '.tws-body strong{color:rgba(255,255,255,0.88);font-weight:400;}',

    /* Divider */
    '.tws-divider{height:1px;background:rgba(255,255,255,0.09);margin-bottom:20px;}',

    /* Feature pills */
    '.tws-pills{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:24px;}',
    '.tws-pill{font-family:"DM Sans",sans-serif;font-size:9.5px;font-weight:400;letter-spacing:0.06em;color:rgba(255,255,255,0.6);background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);border-radius:20px;padding:5px 11px;}',

    /* CTA button */
    '#twsStartBtn{',
      'width:100%;padding:16px 24px;',
      'background:linear-gradient(90deg,#C7B27A,#b09a68);',
      'border:none;border-radius:8px;',
      'font-family:"DM Sans",sans-serif;font-size:10.5px;font-weight:500;',
      'letter-spacing:0.24em;text-transform:uppercase;color:#2E2F2C;',
      'cursor:pointer;transition:all 0.22s;',
      'box-shadow:0 4px 20px rgba(199,178,122,0.28);',
      'display:flex;align-items:center;justify-content:center;gap:10px;',
      'margin-bottom:10px;',
    '}',
    '#twsStartBtn:hover{background:linear-gradient(90deg,#d4c08a,#C7B27A);transform:translateY(-1px);box-shadow:0 8px 28px rgba(199,178,122,0.4);}',
    '#twsStartBtn .btn-arrow{font-size:15px;transition:transform 0.2s;}',
    '#twsStartBtn:hover .btn-arrow{transform:translateX(3px);}',

    /* Micro copy */
    '.tws-micro{text-align:center;font-family:"DM Sans",sans-serif;font-size:10px;font-weight:300;color:rgba(255,255,255,0.38);letter-spacing:0.04em;margin-bottom:18px;}',

    /* Social proof */
    '.tws-social{display:flex;align-items:center;justify-content:center;gap:8px;padding-top:14px;border-top:1px solid rgba(255,255,255,0.08);}',
    '.tws-stars{display:flex;gap:2px;}',
    '.tws-stars span{font-size:10px;color:#C7B27A;}',
    '.tws-social-text{font-family:"DM Sans",sans-serif;font-size:10px;color:rgba(255,255,255,0.45);letter-spacing:0.04em;}',
    '.tws-social-text strong{color:rgba(255,255,255,0.65);font-weight:500;}',

    /* Ribbon */
    '#twsRibbon{position:fixed;right:0;top:50%;transform:translateY(-50%) translateX(100%);z-index:99997;transition:transform 0.4s cubic-bezier(0.4,0,0.2,1);}',
    '#twsRibbon.visible{transform:translateY(-50%) translateX(0);}',
    '#twsRibbon button{writing-mode:vertical-rl;text-orientation:mixed;background:linear-gradient(180deg,#7C8A5A,#5a6147);color:#fff;border:none;padding:24px 15px;font-family:"Cormorant Garamond",Georgia,serif;font-size:14px;font-weight:500;letter-spacing:0.2em;text-transform:uppercase;cursor:pointer;border-radius:6px 0 0 6px;box-shadow:-4px 0 20px rgba(30,31,28,0.22);transition:all 0.2s;min-width:48px;min-height:150px;}',
    '#twsRibbon button:hover{background:linear-gradient(180deg,#C7B27A,#b09a68);}',

    /* Mobile */
    '@media(max-width:480px){',
      '#twsPop{padding:0;}',
      '#twsCard{max-width:100%;border-radius:0;min-height:100vh;display:flex;flex-direction:column;justify-content:center;}',
      '#twsInner{padding:40px 24px 32px;}',
      '#twsInner h2{font-size:26px;}',
    '}'
  ].join('');
  document.head.appendChild(s);
}

/* ── HTML ── */
function injectHTML(){
  if(document.getElementById('twsPop')) return;
  var w=document.createElement('div');
  w.innerHTML=
    '<div id="twsPop">'
    +  '<div id="twsCard">'
    +    '<button id="twsClose" aria-label="Close">&#x2715;</button>'
    +    '<div id="twsInner">'

    +      '<div class="tws-eyebrow">'
    +        '<div class="tws-eyebrow-line"></div>'
    +        '<span>Two Wild Souls Photography</span>'
    +        '<div class="tws-eyebrow-line"></div>'
    +      '</div>'

    +      '<div class="tws-spots"><div class="tws-spots-dot"></div><span>6 spots / month</span></div>'

    +      '<div class="tws-consult-label">Personalized Maternity Consultation</div>'

    +      '<h2>Find your <em>perfect</em><br>session window.</h2>'

    +      '<p class="tws-body">In <strong>20 seconds</strong> we\'ll build your custom recommendation — your ideal week range, booking urgency, and quote.</p>'

    +      '<div class="tws-divider"></div>'

    +      '<div class="tws-pills">'
    +        '<div class="tws-pill">Pro Hair + Makeup</div>'
    +        '<div class="tws-pill">Designer Gowns</div>'
    +        '<div class="tws-pill">In-Studio &amp; Outdoors</div>'
    +      '</div>'

    +      '<button id="twsStartBtn" onclick="twsLaunchQuiz()">'
    +        '<span>Get My Instant Quote</span>'
    +        '<span class="btn-arrow">&#x2192;</span>'
    +      '</button>'

    +      '<p class="tws-micro">Takes 20 seconds &nbsp;·&nbsp; No personal information required</p>'

    +      '<div class="tws-social">'
    +        '<div class="tws-stars"><span>★</span><span>★</span><span>★</span><span>★</span><span>★</span></div>'
    +        '<div class="tws-social-text"><strong>5.0</strong> &nbsp;·&nbsp; 67 Google reviews</div>'
    +      '</div>'

    +    '</div>'
    +  '</div>'
    +'</div>'
    +'<div id="twsRibbon"><button onclick="twsRibbonOpen()" aria-label="Reopen timing calculator">Get Maternity Quote...</button></div>';

  while(w.firstChild) document.body.appendChild(w.firstChild);
  document.getElementById('twsClose').onclick = twsDismiss;
  document.getElementById('twsPop').addEventListener('click',function(e){ if(e.target===this) twsDismiss(); });
}

/* ── Launch — navigate full tab to quiz ── */
window.twsLaunchQuiz = function(){
  var urlParams = new URLSearchParams(window.location.search);
  var dest      = QUIZ_URL;
  var extras    = ['start=1'];
  if(urlParams.get('fbclid')) extras.push('fbclid='+encodeURIComponent(urlParams.get('fbclid')));
  if(urlParams.get('gclid'))  extras.push('gclid='+encodeURIComponent(urlParams.get('gclid')));
  if(extras.length) dest += '?' + extras.join('&');
  window.location.href = dest;
};

/* ── Show / Dismiss ── */
function twsShow(){ var p=document.getElementById('twsPop'); if(p) p.classList.add('open'); }

window.twsDismiss = function(){
  var p=document.getElementById('twsPop');
  if(p){
    p.style.transition='opacity 0.2s ease'; p.style.opacity='0';
    setTimeout(function(){ p.classList.remove('open'); p.style.opacity=''; p.style.transition=''; showRibbon(); },200);
  }
  setDismissed(); clearTimer();
};

/* ── Ribbon ── */
function showRibbon(){
  if(isExcludedPage()) return;
  setRibbonActive();
  var el=document.getElementById('twsRibbon');
  if(!el){ injectRibbon(); el=document.getElementById('twsRibbon'); }
  if(!el) return;
  requestAnimationFrame(function(){ requestAnimationFrame(function(){ el.classList.add('visible'); }); });
}
function hideRibbon(){ var r=document.getElementById('twsRibbon'); if(r) r.classList.remove('visible'); }
function injectRibbon(){
  if(document.getElementById('twsRibbon')) return;
  var el=document.createElement('div'); el.id='twsRibbon';
  el.innerHTML='<button onclick="twsRibbonOpen()" aria-label="Reopen timing calculator">Get Maternity Quote...</button>';
  document.body.appendChild(el);
}

/* ── Manual triggers ── */
window.twsOpen = function(){
  try{ localStorage.removeItem(DISMISS_KEY); }catch(e){}
  hideRibbon(); clearRibbonActive();
  if(!document.getElementById('twsPop')){ injectStyles(); injectHTML(); }
  twsShow();
};
window.twsRibbonOpen = function(){
  hideRibbon(); clearRibbonActive();
  try{ localStorage.removeItem(DISMISS_KEY); }catch(e){}
  if(!document.getElementById('twsPop')){ injectStyles(); injectHTML(); }
  twsShow();
};

/* ── Core init ── */
function tryInit(){
  var log=function(m){ console.log('[TWS Popup v6] '+m); };

  if(isRibbonActive()){
    if(isExcludedPage()){ log('Excluded — ribbon suppressed'); return; }
    log('Ribbon active — restoring tab');
    injectStyles(); injectRibbon(); showRibbon(); return;
  }

  if(isDismissed()){ log('Suppressed — dismissed within 7 days'); return; }
  if(isExcludedPage()){ log('Excluded page — popup blocked'); return; }

  if(isQualifyingMaternityPage()){ log('Qualifying page — flagging'); setFlag(); setTimerStart(); }
  else{ log('Not a qualifying page'); }

  if(!isFlagged()){ log('Not flagged yet'); return; }

  var elapsed  =timeElapsed();
  var remaining=TEST_MODE?0:Math.max(0,DELAY_MS-elapsed);
  log('Elapsed: '+Math.round(elapsed/1000)+'s, remaining: '+Math.round(remaining/1000)+'s');

  if(remaining===0){
    log('Firing popup now');
    if(!document.getElementById('twsPop')){ injectStyles(); injectHTML(); }
    twsShow();
  } else {
    log('Scheduled in '+Math.round(remaining/1000)+'s');
    setTimeout(function(){
      if(isDismissed()){ log('Cancelled — dismissed during wait'); return; }
      if(isExcludedPage()){ log('Cancelled — excluded page'); return; }
      if(!document.getElementById('twsPop')){ injectStyles(); injectHTML(); }
      twsShow();
    }, remaining);
  }
}

if(document.readyState==='loading'){
  document.addEventListener('DOMContentLoaded',tryInit);
} else { tryInit(); }

window.addEventListener('popstate',tryInit);
window.addEventListener('hashchange',tryInit);

})();
</script>
