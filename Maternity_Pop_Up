          +'<div class="tws-nav"><button class="tws-back" onclick="twsGo(4,3)">&#x2190; Back</button></div>'
        +'</div>'

        /* Step 5 — Who's joining */
        +'<div class="tws-step" id="tws-s5">'
          +'<p class="tws-q">Who\'s joining you for photos?</p>'
          +'<p class="tws-hint">This helps us match you to the right experience.</p>'
          +'<div class="tws-opts">'
            +'<div class="tws-opt" onclick="twsPick(\'whoJoins\',\'momOnly\',this,5,0)"><div class="ot">Just me 🤍</div><div class="od">Intimate studio portraits — all about you and your bump</div></div>'
            +'<div class="tws-opt" onclick="twsPick(\'whoJoins\',\'partner\',this,5,0)"><div class="ot">Me + my partner 💑</div><div class="od">Include your husband or partner in some or all shots</div></div>'
            +'<div class="tws-opt" onclick="twsPick(\'whoJoins\',\'family\',this,5,0)"><div class="ot">The whole family 👨‍👩‍👧</div><div class="od">Partner, kids, fur babies — everyone welcome</div></div>'
          +'</div>'
          +'<p class="tws-err" id="tws-e5">Please make a selection to continue.</p>'
          +'<div class="tws-nav"><button class="tws-back" onclick="twsGo(5,4)">&#x2190; Back</button></div>'
        +'</div>'

        /* Loading */
        +'<div id="twsLoad">'
          +'<div class="tws-spinner"></div>'
          +'<div class="tws-load-pkg" id="twsLoadPkg"></div>'
          +'<div class="tws-load-tag" id="twsLoadTag"></div>'
          +'<p class="tws-load-sub">Building your personalized quote…</p>'
        +'</div>'
      +'</div>'
      +'<div id="twsFoot"><p>Two Wild Souls Photography &nbsp;·&nbsp; Metro Detroit &amp; Southeast Michigan</p></div>'
    +'</div>'
  +'</div>'
  /* Desktop calendar overlay (unchanged) */
  +'<div id="twsCal" onclick="twsCalOverlayClick(event)">'
    +'<div id="twsCalBox">'
      +'<div class="twsCal-head"><button type="button" onclick="twsCalMonth(-1)">&#8249;</button><span id="twsCalLbl"></span><button type="button" onclick="twsCalMonth(1)">&#8250;</button></div>'
      +'<div class="twsCal-wdays"><div>Sun</div><div>Mon</div><div>Tue</div><div>Wed</div><div>Thu</div><div>Fri</div><div>Sat</div></div>'
      +'<div class="twsCal-grid" id="twsCalGrid"></div>'
      +'<div class="twsCal-foot"><button class="twsCal-cancel" type="button" onclick="twsCloseCal()">Cancel</button><button class="twsCal-done" type="button" onclick="twsConfirmCal()">Done</button></div>'
    +'</div>'
  +'</div>';
  while(w.firstChild) document.body.appendChild(w.firstChild);

  document.getElementById('twsClose').onclick = twsDismiss;
  document.getElementById('twsPop').addEventListener('click', function(e){ if(e.target===this) twsDismiss(); });

  /* ── Wire up native date input (mobile) ── */
  var nativeInput = document.getElementById('twsNativeDateInput');
  if(nativeInput){
    /* Set min to ~8 weeks from today to mirror the custom calendar's minimum */
    var minD = new Date(NOW.getTime() + 56*86400000);
    nativeInput.min = minD.toISOString().split('T')[0];
    /* When the user picks a date from the phone picker, commit it */
    nativeInput.addEventListener('change', function(){
      if(!this.value) return;
      /* Parse YYYY-MM-DD safely (avoid UTC-offset midnight issues) */
      var parts = this.value.split('-');
      var picked = new Date(parseInt(parts[0]), parseInt(parts[1])-1, parseInt(parts[2]));
      picked.setHours(0,0,0,0);
      twsCommitDate(picked);
    });
  }

  twsBuildDots(1);
  twsUpdateProg(1);
}

/* ── Shared date-commit logic (used by both pickers) ── */
function twsCommitDate(dateObj){
  ST.due    = dateObj;
  ST.dueStr = dateObj.toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'});
  var btn   = document.getElementById('twsDpBtn');
  if(btn){ btn.textContent = ST.dueStr; btn.classList.add('picked'); }
  document.getElementById('tws-e1').classList.remove('show');
  document.getElementById('twsWarnBox').classList.remove('show');
  /* Auto-advance after a brief moment so the label update is visible */
  setTimeout(function(){ twsGo(1,2); }, 300);
}

/* ── Dots & Progress ── */
function twsBuildDots(n){
  var c = document.getElementById('twsDots'); if(!c) return;
  c.innerHTML = '';
  for(var i=1;i<=5;i++){
    var d=document.createElement('div');
    d.className = 'tws-dot' + (i===n?' on':i<n?' done':'');
    c.appendChild(d);
  }
}
function twsUpdateProg(n){
  var f = document.getElementById('twsProgFill'); if(!f) return;
  f.style.width = (((n-1)/5)*100) + '%';
  twsBuildDots(n);
}

/* ── Calendar toggle: routes to native (mobile) or custom (desktop) ── */
window.twsToggleCal = function(){
  if(isMobile()){
    /* Trigger the hidden native date input */
    var ni = document.getElementById('twsNativeDateInput');
    if(ni){
      /* Pre-fill with current selection so the phone picker opens at the right date */
      if(ST.due){
        var y = ST.due.getFullYear();
        var m = String(ST.due.getMonth()+1).padStart(2,'0');
        var d = String(ST.due.getDate()).padStart(2,'0');
        ni.value = y+'-'+m+'-'+d;
      }
      ni.click();
    }
    return;
  }
  /* Desktop: open custom calendar (unchanged) */
  var cal = document.getElementById('twsCal'); if(!cal) return;
  if(cal.classList.contains('open')){ twsCloseCal(); return; }
  if(ST.due){ calY=ST.due.getFullYear(); calM=ST.due.getMonth(); calTemp=new Date(ST.due); }
  else{
    var fd=new Date(NOW.getTime()+56*86400000); calY=fd.getFullYear(); calM=fd.getMonth(); calTemp=null;
  }
  twsRenderCal(); cal.classList.add('open');
};
window.twsCloseCal  = function(){ var c=document.getElementById('twsCal'); if(c) c.classList.remove('open'); };
window.twsCalMonth  = function(d){ calM+=d; if(calM<0){calM=11;calY--;} if(calM>11){calM=0;calY++;} twsRenderCal(); };
window.twsCalOverlayClick = function(e){ if(e.target===document.getElementById('twsCal')) twsCloseCal(); };
window.twsConfirmCal = function(){
  if(!calTemp){ twsCloseCal(); return; }
  twsCloseCal();
  twsCommitDate(new Date(calTemp));
};
function twsRenderCal(){
  var lbl = document.getElementById('twsCalLbl'); if(!lbl) return;
  lbl.textContent = MONTHS[calM]+' '+calY;
  var grid = document.getElementById('twsCalGrid'); if(!grid) return;
  grid.innerHTML = '';
  var fd = new Date(calY,calM,1).getDay();
  var dim = new Date(calY,calM+1,0).getDate();
  var minDate = new Date(NOW.getTime()+56*86400000);
  for(var i=0;i<fd;i++){ var e=document.createElement('button'); e.className='twsCal-day emp'; e.type='button'; grid.appendChild(e); }
  for(var d=1;d<=dim;d++){
    var dt=new Date(calY,calM,d); dt.setHours(0,0,0,0);
    var b=document.createElement('button'); b.type='button'; b.className='twsCal-day'; b.textContent=d;
    if(dt<minDate){ b.classList.add('dis'); }
    else{
      if(calTemp){ var t=new Date(calTemp); t.setHours(0,0,0,0); if(dt.getTime()===t.getTime()) b.classList.add('sel'); }
      (function(x,btn2){ btn2.addEventListener('click',function(){
        calTemp=new Date(x);
        grid.querySelectorAll('.twsCal-day').forEach(function(bb){ bb.classList.remove('sel'); });
        btn2.classList.add('sel');
      }); })(dt,b);
    }
    grid.appendChild(b);
  }
}

/* ── Navigation ── */
window.twsGo = function(from, to){
  if(to > from && !twsValidate(from)) return;
  var fEl = document.getElementById('tws-s'+from);
  var tEl = document.getElementById('tws-s'+to);
  if(fEl) fEl.classList.remove('active');
  if(tEl){ tEl.classList.add('active'); twsUpdateProg(to); }
};

/* ── Validation ── */
function twsValidate(s){
  if(s===1){
    var e=document.getElementById('tws-e1'), wb=document.getElementById('twsWarnBox');
    if(!ST.due){ e.classList.add('show'); wb.classList.remove('show'); return false; }
    e.classList.remove('show');
    var wk = twsCurrentWeek(ST.due);
    if(wk >= 34){ wb.classList.add('show'); return false; }
    wb.classList.remove('show'); return true;
  }
  var map={2:['tws-e2','firstBaby'],3:['tws-e3','multiples'],4:['tws-e4','style'],5:['tws-e5','whoJoins']};
  if(map[s]){
    var err=document.getElementById(map[s][0]);
    if(!ST[map[s][1]]){ err.classList.add('show'); return false; }
    err.classList.remove('show');
  }
  return true;
}

/* ── Auto-advance picks ── */
window.twsPick = function(key, val, el, fromStep, toStep){
  var parent = el.closest ? el.closest('.tws-opts') : el.parentNode;
  var siblings = parent.querySelectorAll('.tws-opt');
  for(var i=0;i<siblings.length;i++) siblings[i].classList.remove('sel');
  el.classList.add('sel'); ST[key] = val;
  var err = document.getElementById('tws-e'+fromStep); if(err) err.classList.remove('show');
  if(toStep === 0){
    setTimeout(twsCalcResult, 280);
  } else {
    setTimeout(function(){ twsGo(fromStep, toStep); }, 280);
  }
};

/* ── Week helpers ── */
function twsCurrentWeek(dueDate){
  var conception = new Date(dueDate.getTime() - 280*86400000);
  var daysSince = Math.floor((NOW - conception)/86400000);
  return Math.max(1, Math.min(42, Math.ceil(daysSince/7)));
}

/* ── Calculate & redirect ── */
function twsCalcResult(){
  for(var i=1;i<=5;i++){
    var s=document.getElementById('tws-s'+i); if(s) s.classList.remove('active');
  }
  var pkg = ST.whoJoins==='momOnly' ? 'portraits' : 'whiteGlove';
  var p = PACKAGES[pkg];
  document.getElementById('twsLoadPkg').textContent = p.emoji+' '+p.name;
  document.getElementById('twsLoadTag').textContent = p.tagline;
  document.getElementById('twsLoad').classList.add('active');
  twsUpdateProg(5);

  setTimeout(function(){
    var due       = ST.due;
    var isFirst   = ST.firstBaby === 'yes';
    var multiples = ST.multiples === 'yes';
    var style     = ST.style || 'full';
    var setting   = ST.whoJoins === 'momOnly' ? 'indoor' : 'both';
    var highRisk  = ST.highRisk;

    var currentWeek = twsCurrentWeek(due);
    var conception  = new Date(due.getTime() - 280*86400000);

    var startWeek, endWeek;
    if(multiples){
      startWeek=24; endWeek=28;
    } else if(!isFirst){
      startWeek = style==='full'?28:26;
      endWeek   = style==='full'?32:30;
    } else {
      startWeek = style==='full'?30:28;
      endWeek   = style==='full'?34:32;
    }

    if(!multiples){
      if(setting==='outdoor'){  startWeek=Math.max(20,startWeek-2); endWeek=Math.max(22,endWeek-2); }
      else if(setting==='indoor'){ startWeek=Math.min(32,startWeek+1); endWeek=Math.min(34,endWeek+1); }
    }
    if(highRisk && !multiples){ startWeek=Math.max(20,startWeek-2); endWeek=Math.max(22,endWeek-2); }

    endWeek   = Math.min(endWeek,   32);
    startWeek = Math.min(startWeek, 32);

    var isLate     = currentWeek >= 33;
    var isUrgent   = currentWeek === 32;
    var isInWindow = currentWeek >= startWeek && currentWeek <= endWeek && !isUrgent && !isLate;

    var context = 'early';
    if(isLate||isUrgent)          context='late';
    else if(isInWindow)           context='inWindow';
    else if(currentWeek>endWeek)  context='pastWindow';

    var bookByStr = '';
    if(!isLate && !isUrgent){
      var bookDate = new Date(conception.getTime()+(startWeek*7-42)*86400000);
      bookByStr = bookDate.toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'});
    } else if(isUrgent){
      bookByStr = 'Today';
    }

    var maternityUrl = 'https://twowildsoulsphotography.com/personalized-maternity-results';
    var newbornUrl   = 'https://twowildsoulsphotography.com/detroit-newborn-photographer-ads';
    var dest = isLate ? newbornUrl : maternityUrl;

    var params = new URLSearchParams({
      week:    currentWeek,
      status:  context,
      window:  (isLate||isUrgent) ? '' : (startWeek+'-'+endWeek),
      bookby:  bookByStr,
      type:    isLate ? 'newborn' : 'maternity',
      style:   style,
      setting: setting,
      package: pkg,
      duedate: due.toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'})
    });

    var urlP = new URLSearchParams(window.location.search);
    var fbclid=urlP.get('fbclid'), gclid=urlP.get('gclid');
    if(fbclid) params.append('fbclid',fbclid);
    if(gclid)  params.append('gclid',gclid);

    try{ fbq('track','Lead',{content_name:'Calculator Complete',content_category:context,value:currentWeek,currency:'USD'}); }catch(e){}

    window.location.href = dest + '?' + params.toString();
  }, 1600);
}

/* ── Ribbon ── */
function isExcludedPage(){
  var u=window.location.href.toLowerCase();
  for(var i=0;i<EXCLUDED.length;i++){ if(u.indexOf('/'+EXCLUDED[i])!==-1) return true; }
  return false;
}
function injectRibbon(){
  if(document.getElementById('twsRibbon')) return;
  var el=document.createElement('div'); el.id='twsRibbon';
  el.innerHTML='<button onclick="twsRibbonOpen()" aria-label="Reopen timing calculator">Get Maternity Quote...</button>';
  document.body.appendChild(el);
}
function showRibbon(){
  if(isExcludedPage()) return;
  setRibbonActive(); injectRibbon();
  requestAnimationFrame(function(){ requestAnimationFrame(function(){
    var r=document.getElementById('twsRibbon'); if(r) r.classList.add('visible');
  }); });
}
function hideRibbon(){ var r=document.getElementById('twsRibbon'); if(r) r.classList.remove('visible'); }

/* ── Reset quiz ── */
function twsReset(){
  ST = { due:null, dueStr:'', firstBaby:null, multiples:null, style:null, whoJoins:null, highRisk:false };
  for(var i=1;i<=5;i++){ var s=document.getElementById('tws-s'+i); if(s) s.classList.remove('active'); }
  var ld=document.getElementById('twsLoad'); if(ld) ld.classList.remove('active');
  var s1=document.getElementById('tws-s1'); if(s1) s1.classList.add('active');
  var btn=document.getElementById('twsDpBtn');
  if(btn){ btn.textContent='Tap to select your due date...'; btn.classList.remove('picked'); }
  /* Also clear native input value */
  var ni=document.getElementById('twsNativeDateInput'); if(ni) ni.value='';
  var wb=document.getElementById('twsWarnBox'); if(wb) wb.classList.remove('show');
  twsUpdateProg(1);
}

/* ── Show / Dismiss ── */
function twsShow(){ var p=document.getElementById('twsPop'); if(p) p.classList.add('open'); }
window.twsDismiss = function(){
  twsCloseCal();
  var p=document.getElementById('twsPop');
  if(p){ p.style.transition='opacity 0.2s ease'; p.style.opacity='0';
    setTimeout(function(){ p.classList.remove('open'); p.style.opacity=''; p.style.transition=''; showRibbon(); },200); }
  setDismissed(); clearTimer();
};

/* ── Manual triggers ── */
window.twsOpen = function(){
  try{ localStorage.removeItem(DISMISS_KEY); }catch(e){}
  hideRibbon(); clearRibbonActive();
  if(!document.getElementById('twsPop')){ injectStyles(); injectHTML(); }
  else twsReset();
  twsShow();
};
window.twsRibbonOpen = function(){
  hideRibbon(); clearRibbonActive();
  try{ localStorage.removeItem(DISMISS_KEY); }catch(e){}
  if(!document.getElementById('twsPop')){ injectStyles(); injectHTML(); }
  else twsReset();
  twsShow();
};

/* ── Core init ── */
function tryInit(){
  var log=function(m){ console.log('[TWS Popup] '+m); };

  if(isRibbonActive()){
    if(isExcludedPage()){ log('Excluded — ribbon suppressed'); return; }
    log('Ribbon active — restoring tab');
    injectStyles(); showRibbon(); return;
  }

  if(isDismissed()){ log('Suppressed — dismissed within 7 days'); return; }
  if(isExcludedPage()){ log('Excluded page — popup blocked'); return; }

  if(isQualifyingMaternityPage()){ log('Qualifying page — flagging'); setFlag(); setTimerStart(); }
  else { log('Not a qualifying page'); }

  if(!isFlagged()){ log('Not flagged yet'); return; }

  var elapsed=timeElapsed();
  var remaining=TEST_MODE?0:Math.max(0,DELAY_MS-elapsed);
  log('Elapsed: '+Math.round(elapsed/1000)+'s, remaining: '+Math.round(remaining/1000)+'s');

  if(remaining===0){
    log('Firing popup now');
    if(!document.getElementById('twsPop')){ injectStyles(); injectHTML(); }
    twsShow();
  } else {
    log('Scheduled in '+Math.round(remaining/1000)+'s');
    setTimeout(function(){
      if(isDismissed()){ log('Cancelled — dismissed during wait'); return; }
      if(isExcludedPage()){ log('Cancelled — excluded page'); return; }
      if(!document.getElementById('twsPop')){ injectStyles(); injectHTML(); }
      twsShow();
    }, remaining);
  }
}

if(document.readyState==='loading'){
  document.addEventListener('DOMContentLoaded', tryInit);
} else { tryInit(); }

window.addEventListener('popstate', tryInit);
window.addEventListener('hashchange', tryInit);

})();
</script>
